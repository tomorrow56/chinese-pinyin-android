<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="中文ピンイン変換"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="16dp" />

        <!-- Image Preview Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="画像プレビュー"
                        android:textSize="14sp"
                        android:textColor="#757575" />

                    <!-- クロップし直しボタン（画像選択後に表示） -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCrop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="範囲を選択"
                        android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/colorPrimary"
                        app:icon="@android:drawable/ic_menu_crop" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerInside"
                    android:background="#EEEEEE"
                    android:contentDescription="選択した画像のプレビュー" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Button Row: ギャラリー / カメラ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectImage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/select_image"
                android:layout_marginEnd="6dp"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_gallery"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/colorPrimary"
                android:textColor="@color/colorPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTakePhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/take_photo"
                android:layout_marginStart="6dp"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_camera"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/colorPrimary"
                android:textColor="@color/colorPrimary" />

        </LinearLayout>

        <!-- 認識ボタン -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecognize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/recognize"
            android:textSize="16sp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/colorPrimary" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Recognized Chinese Text Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardRecognized"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recognized_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#757575" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/copy_text"
                        android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/colorPrimary" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvRecognizedText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/chinese_text_color"
                    android:lineSpacingMultiplier="1.5"
                    android:background="#F9F9F9"
                    android:padding="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pinyin Result Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPinyin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pinyin_result"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#757575" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyPinyin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/copy_pinyin"
                        android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/colorPrimary" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvPinyin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="@color/pinyin_text_color"
                    android:lineSpacingMultiplier="1.8"
                    android:background="#FFF8F8"
                    android:padding="12dp"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ruby (Furigana-style) Display Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardRuby"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ルビ表示（漢字＋ピンイン）"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.example.chinesepinyin.RubyTextView
                    android:id="@+id/rubyTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFDE7"
                    android:padding="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
